ndondomeko yochepa(a, b) {
    ngati (a > b) {
        bweza b;
    }
    bweza a;
}

ndondomeko sqrt(n) {
    nambala x = n;
    nambala y = 1;
    ngati (n == 0 || n == 1) {
        bweza n;
    }
    za(nambala i = 0; y <= x; i++) {
        x = (x + y) / 2;
        y = n / x;
    }
    bweza x;
}